    <string name="settings_reflow_on_keyboard_subtitle">When the keyboard opens, resize the terminal to fit above it instead of scrolling the view up. Helps full-screen apps that show a status line at the top; leave off for plain shells.</string>
    <string name="settings_gpu_venus_title">Experimental GPU stack (venus + zink)</string>
    <string name="settings_gpu_venus_subtitle">Use venus (Vulkan to the GPU) + zink for modern OpenGL (~3.2 core) on accelerated desktops, instead of virgl (GL 2.1). Native Vulkan apps display; OpenGL present is currently slow. Needs mesa-vulkan-drivers installed in the guest. Off = virgl default.</string>
    <string name="settings_touchpad_input_title">Touchpad input</string>
    <string name="settings_touchpad_input_direct_subtitle">Direct touch — finger position is the pointer. Toggle on for trackpad-style input.</string>
    <string name="settings_touchpad_input_touchpad_subtitle">Drag moves the remote cursor; tap clicks at the cursor. The viewport follows the cursor when zoomed.</string>
    <string name="settings_bandwidth_suggest_title">Suggest 256 colours on slow VNC links</string>
    <string name="settings_bandwidth_suggest_subtitle">Detects throughput below ~1 Mbps after a few seconds and offers a one-tap reconnect at 256 colours. Off silences the prompt.</string>

