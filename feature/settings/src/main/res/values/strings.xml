    <string name="settings_ime_flag_auto_correct_detail">TYPE_TEXT_FLAG_AUTO_CORRECT — required by Samsung Honeyboard\'s commit-text gate (#110); explicitly enables autocorrect on Gboard.</string>
    <string name="settings_ime_flag_full_editor_title">Voice &amp; swipe (full editor)</string>
    <string name="settings_ime_flag_full_editor_detail">Give the IME a real Editable. Needed for voice input, swipe typing, and CJK composition. Conflicts with the autocorrect-suppression hint above.</string>
