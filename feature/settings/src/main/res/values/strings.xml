    <string name="settings_right_click_subtitle">Send right-click to terminal instead of starting text selection. Useful for tmux context menus</string>
    <string name="settings_standard_keyboard_title">Voice input and autocomplete</string>
    <string name="settings_standard_keyboard_subtitle">Disables secure keyboard flags (password mode, no suggestions). Enables voice input, swipe typing, and word predictions — but the IME may learn typed passwords</string>

