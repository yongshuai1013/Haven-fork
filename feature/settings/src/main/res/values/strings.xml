    <!-- MCP agent endpoint -->
    <string name="settings_agent_endpoint_title">Agent endpoint (MCP)</string>
    <string name="settings_agent_endpoint_subtitle_on">Enabled — local MCP server on loopback. Write tools prompt for consent.</string>
    <string name="settings_agent_endpoint_subtitle_off">Disabled — turn on to let local AI agents read state and (with consent) act on it</string>
    <string name="settings_agent_file_read_title">Allow agents to read file contents</string>
    <string name="settings_agent_file_read_subtitle_on">Enabled — `serve_file` returns a single-use download URL after per-call consent</string>
    <string name="settings_agent_file_read_subtitle_off">Disabled — `serve_file` requests fail immediately, no prompt</string>
    <string name="settings_agent_terminal_input_title">Allow agents to queue terminal input</string>
    <string name="settings_agent_terminal_input_subtitle_on">Enabled — `queue_terminal_input` watches the SSH session\'s output and types the queued text on the next prompt (per-call consent)</string>
    <string name="settings_agent_terminal_input_subtitle_off">Disabled — `queue_terminal_input` requests fail immediately, no prompt</string>
    <string name="settings_reverse_tunnel_title">Always-on MCP connection</string>
    <string name="settings_reverse_tunnel_subtitle_set">Tunnelled to \"%1$s\" — survives WiFi changes &amp; app restarts</string>
    <string name="settings_reverse_tunnel_subtitle_unset">Not set — endpoint reachable on-device only</string>
    <string name="settings_reverse_tunnel_none">None (on-device only)</string>
    <string name="settings_mcp_wireguard_title">Expose on WireGuard tunnel</string>
    <string name="settings_mcp_wireguard_subtitle_on">Enabled — also reachable at &lt;wg-ip&gt;:8730 on the active WireGuard tunnel</string>
    <string name="settings_mcp_wireguard_subtitle_off">Disabled — turn on to reach the endpoint over an active WireGuard tunnel</string>
    <string name="settings_mcp_wireguard_collision">Another VPN (%1$s) is using %2$s — the same address this endpoint binds, so it\'s shadowed and unreachable from peers. Stop that VPN, or point your MCP client at the loopback (127.0.0.1) endpoint instead.</string>
    <string name="settings_mcp_lan_title">Expose on Wi-Fi/LAN</string>
    <string name="settings_mcp_lan_subtitle_on">Enabled — also reachable at &lt;device-lan-ip&gt;:8730 on the local network</string>
    <string name="settings_mcp_lan_subtitle_off">Disabled — turn on for direct reach from a device on the same Wi-Fi/LAN</string>
    <string name="settings_mcp_trust_loopback_title">Trust local clients</string>
    <string name="settings_mcp_trust_loopback_subtitle_on">Enabled — local clients (127.0.0.1) connect without pairing or approval prompts. Wi-Fi/LAN and WireGuard clients still prompt.</string>
    <string name="settings_mcp_trust_loopback_subtitle_off">Disabled — even local clients must be paired and approve each request</string>
