    <string name="app_desktop_compositor_title">Compositor</string>
    <string name="app_desktop_mirror_title">Espejo de paquetes</string>
    <string name="app_desktop_mirror_description">De dónde se descargan los paquetes de la distribución. Elige una región cercana para instalaciones más rápidas y fiables. El valor predeterminado usa el CDN propio de cada distribución.</string>
    <string name="app_desktop_mirror_default">Predeterminado (CDN)</string>
    <string name="app_desktop_mirror_europe">Europa</string>
    <string name="app_desktop_mirror_asia">Asia</string>
    <string name="app_desktop_mirror_americas">América</string>
    <string name="app_desktop_remap_ports_title">Reasignar puertos bajos</string>
    <string name="app_desktop_remap_ports_description">Permite que los servicios del invitado escuchen en puertos privilegiados (&lt;1024): un servicio en el puerto N pasa a estar accesible en N+2000 (p. ej. 80 → 2080). Android impide que la app vincule puertos bajos directamente. Desactivado por defecto; afecta a cada puerto privilegiado, incluido un sshd del invitado.</string>
    <string name="app_desktop_share_storage_title">Compartir el almacenamiento del dispositivo con el invitado</string>
    <string name="app_desktop_share_storage_description">Monta tu almacenamiento compartido en el invitado en /storage y /sdcard para que pueda acceder a tus archivos. Desactívalo para mantener tus fotos y descargas ocultas del entorno Linux local.</string>
    <string name="app_desktop_bind_android_system_title">Exponer el sistema Android al invitado</string>
    <string name="app_desktop_bind_android_system_description">Monta en el invitado las particiones de solo lectura de Android /system, /vendor, /apex y relacionadas, para que pueda ejecutar los binarios nativos de Android (p. ej. getprop, toybox). Desactivado por defecto: esto expone los internos del dispositivo y del fabricante al entorno Linux local.</string>
    <string name="app_desktop_custom_binds_title">Montajes personalizados (%1$d)</string>
    <string name="app_desktop_custom_binds_description">Expone rutas de Android adicionales dentro del invitado de esta distribución, además de los montajes del sistema. Los montajes son de lectura y escritura.</string>
    <string name="app_desktop_custom_binds_dialog_title">Montajes personalizados — %1$s</string>
    <string name="app_desktop_custom_binds_host_hint">Ruta de Android (p. ej. /storage/emulated/0/Sync)</string>
    <string name="app_desktop_custom_binds_guest_hint">Ruta en el invitado (opcional — por defecto la misma ruta)</string>
    <string name="app_desktop_custom_binds_add">Añadir montaje</string>
    <string name="app_desktop_custom_binds_empty">No hay montajes personalizados. Añade uno para exponer una ruta de Android en el invitado.</string>
    <string name="app_desktop_custom_binds_remove_cd">Quitar montaje</string>
    <string name="app_desktop_custom_binds_takes_effect">Se aplica en el próximo inicio de un shell, un comando o un escritorio de esta distribución.</string>
    <string name="app_desktop_import_rootfs">Importar rootfs…</string>
    <string name="app_desktop_options_section">Opciones y montajes</string>
    <string name="app_desktop_open_usb_drive">Abrir unidad USB…</string>
    <string name="app_desktop_open_usb_drive_writable">Abrir unidad USB (escritura)…</string>
    <string name="app_desktop_open_usb_drive_writable_confirm_title">¿Montar en lectura y escritura?</string>
    <string name="app_desktop_open_usb_drive_writable_confirm_body">Esto monta la unidad en lectura y escritura. Si la VM pierde la alimentación en mitad de una escritura (cierre forzado, fallo, batería retirada), el sistema de archivos puede corromperse. Solo lectura es el valor predeterminado más seguro.</string>
