    <string name="app_desktop_mirror_title">पैकेज मिरर</string>
    <string name="app_desktop_mirror_description">distro पैकेज कहाँ से डाउनलोड होते हैं। तेज़ और अधिक भरोसेमंद इंस्टॉल के लिए अपने नज़दीकी क्षेत्र को चुनें। डिफ़ॉल्ट हर distro का अपना CDN उपयोग करता है।</string>
    <string name="app_desktop_mirror_default">डिफ़ॉल्ट (CDN)</string>
    <string name="app_desktop_mirror_europe">यूरोप</string>
    <string name="app_desktop_mirror_asia">एशिया</string>
    <string name="app_desktop_mirror_americas">अमेरिका</string>
    <string name="app_desktop_remap_ports_title">निचले पोर्ट रीमैप करें</string>
    <string name="app_desktop_remap_ports_description">गेस्ट सेवाओं को विशेषाधिकार-प्राप्त पोर्ट (&lt;1024) पर सुनने देता है: पोर्ट N की सेवा N+2000 पर उपलब्ध हो जाती है (जैसे 80 → 2080)। Android ऐप को निचले पोर्ट सीधे बाइंड करने से रोकता है। डिफ़ॉल्ट रूप से बंद; गेस्ट sshd सहित हर विशेषाधिकार-प्राप्त पोर्ट पर लागू होता है।</string>
    <string name="app_desktop_share_storage_title">डिवाइस स्टोरेज गेस्ट के साथ साझा करें</string>
    <string name="app_desktop_share_storage_description">आपके साझा स्टोरेज को गेस्ट में /storage और /sdcard पर माउंट करता है ताकि वह आपकी फ़ाइलों तक पहुँच सके। अपनी फ़ोटो और डाउनलोड स्थानीय Linux वातावरण से छिपाए रखने के लिए बंद करें।</string>
    <string name="app_desktop_bind_android_system_title">Android सिस्टम गेस्ट को एक्सपोज़ करें</string>
    <string name="app_desktop_bind_android_system_description">Android के रीड-ओनली /system, /vendor, /apex और संबंधित पार्टीशन गेस्ट में माउंट करता है ताकि वह Android के अपने नेटिव बाइनरी (जैसे getprop, toybox) चला सके। डिफ़ॉल्ट रूप से बंद: यह डिवाइस और वेंडर की आंतरिक जानकारी स्थानीय Linux वातावरण के सामने खोल देता है।</string>
    <string name="app_desktop_custom_binds_title">कस्टम माउंट (%1$d)</string>
    <string name="app_desktop_custom_binds_description">सिस्टम माउंट के अलावा इस distro के गेस्ट में अतिरिक्त Android पथ एक्सपोज़ करें। माउंट रीड-राइट होते हैं।</string>
    <string name="app_desktop_custom_binds_dialog_title">कस्टम माउंट — %1$s</string>
    <string name="app_desktop_custom_binds_host_hint">Android पथ (जैसे /storage/emulated/0/Sync)</string>
    <string name="app_desktop_custom_binds_guest_hint">गेस्ट पथ (वैकल्पिक — डिफ़ॉल्ट वही पथ)</string>
    <string name="app_desktop_custom_binds_add">माउंट जोड़ें</string>
    <string name="app_desktop_custom_binds_empty">कोई कस्टम माउंट नहीं। गेस्ट में कोई Android पथ एक्सपोज़ करने के लिए एक जोड़ें।</string>
    <string name="app_desktop_custom_binds_remove_cd">माउंट हटाएँ</string>
    <string name="app_desktop_custom_binds_takes_effect">इस distro के अगले शेल, कमांड या डेस्कटॉप शुरू होने पर लागू होता है।</string>
