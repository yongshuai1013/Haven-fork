    <string name="app_desktop_compositor_title">Compositor</string>
    <string name="app_desktop_mirror_title">Paketspiegel</string>
    <string name="app_desktop_mirror_description">Legt fest, woher Distributionspakete heruntergeladen werden. Wähle eine Region in deiner Nähe für schnellere, zuverlässigere Installationen. Standard verwendet das eigene CDN jeder Distribution.</string>
    <string name="app_desktop_mirror_default">Standard (CDN)</string>
    <string name="app_desktop_mirror_europe">Europa</string>
    <string name="app_desktop_mirror_asia">Asien</string>
    <string name="app_desktop_mirror_americas">Amerika</string>
    <string name="app_desktop_remap_ports_title">Niedrige Ports umleiten</string>
    <string name="app_desktop_remap_ports_description">Erlaubt Gast-Diensten, auf privilegierten Ports (&lt;1024) zu lauschen: Ein Dienst auf Port N wird unter N+2000 erreichbar (z. B. 80 → 2080). Android verhindert, dass die App niedrige Ports direkt bindet. Standardmäßig aus; betrifft jeden privilegierten Port, auch einen sshd im Gast.</string>
    <string name="app_desktop_share_storage_title">Gerätespeicher mit dem Gast teilen</string>
    <string name="app_desktop_share_storage_description">Bindet deinen gemeinsamen Speicher unter /storage und /sdcard in den Gast ein, damit er auf deine Dateien zugreifen kann. Ausschalten, um Fotos und Downloads vor der lokalen Linux-Umgebung verborgen zu halten.</string>
    <string name="app_desktop_bind_android_system_title">Android-System dem Gast bereitstellen</string>
    <string name="app_desktop_bind_android_system_description">Bindet Androids schreibgeschützte Partitionen /system, /vendor, /apex und verwandte in den Gast ein, damit er Androids eigene native Binärdateien ausführen kann (z. B. getprop, toybox). Standardmäßig aus: Dies legt Geräte- und Hersteller-Interna gegenüber der lokalen Linux-Umgebung offen.</string>
    <string name="app_desktop_custom_binds_title">Eigene Mounts (%1$d)</string>
    <string name="app_desktop_custom_binds_description">Stellt zusätzliche Android-Pfade im Gast dieser Distribution bereit, zusätzlich zu den System-Mounts. Mounts sind beschreibbar.</string>
    <string name="app_desktop_custom_binds_dialog_title">Eigene Mounts — %1$s</string>
    <string name="app_desktop_custom_binds_host_hint">Android-Pfad (z. B. /storage/emulated/0/Sync)</string>
    <string name="app_desktop_custom_binds_guest_hint">Gast-Pfad (optional — Standard: derselbe Pfad)</string>
    <string name="app_desktop_custom_binds_add">Mount hinzufügen</string>
    <string name="app_desktop_custom_binds_empty">Keine eigenen Mounts. Füge einen hinzu, um einen Android-Pfad im Gast bereitzustellen.</string>
    <string name="app_desktop_custom_binds_remove_cd">Mount entfernen</string>
    <string name="app_desktop_custom_binds_takes_effect">Gilt ab dem nächsten Start einer Shell, eines Befehls oder eines Desktops für diese Distribution.</string>
    <string name="app_desktop_import_rootfs">Rootfs importieren…</string>
    <string name="app_desktop_options_section">Optionen &amp; Mounts</string>
    <string name="app_desktop_open_usb_drive">USB-Laufwerk öffnen…</string>
    <string name="app_desktop_open_usb_drive_writable">USB-Laufwerk öffnen (beschreibbar)…</string>
    <string name="app_desktop_open_usb_drive_writable_confirm_title">Mit Schreibzugriff einbinden?</string>
    <string name="app_desktop_open_usb_drive_writable_confirm_body">Dies bindet das Laufwerk mit Schreibzugriff ein. Verliert die VM mitten im Schreibvorgang den Strom (beendet, Absturz, Akku entfernt), kann das Dateisystem beschädigt werden. Nur-Lesen ist der sicherere Standard.</string>
