    <string name="app_desktop_compositor_title">Compositeur</string>
    <string name="app_desktop_mirror_title">Miroir de paquets</string>
    <string name="app_desktop_mirror_description">D\'où sont téléchargés les paquets de la distribution. Choisissez une région proche de vous pour des installations plus rapides et plus fiables. Par défaut, le CDN propre à chaque distribution est utilisé.</string>
    <string name="app_desktop_mirror_default">Par défaut (CDN)</string>
    <string name="app_desktop_mirror_europe">Europe</string>
    <string name="app_desktop_mirror_asia">Asie</string>
