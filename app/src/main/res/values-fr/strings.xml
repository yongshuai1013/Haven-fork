    <string name="app_desktop_remap_ports_title">Remapper les ports bas</string>
    <string name="app_desktop_remap_ports_description">Permet aux services du guest d\'écouter sur les ports privilégiés (&lt;1024) : un service sur le port N devient joignable sur N+2000 (ex. 80 → 2080). Android empêche l\'appli de lier directement les ports bas. Désactivé par défaut ; concerne tous les ports privilégiés, y compris un sshd du guest.</string>
    <string name="app_desktop_share_storage_title">Partager le stockage de l\'appareil avec le guest</string>
    <string name="app_desktop_share_storage_description">Monte votre stockage partagé dans le guest sous /storage et /sdcard pour qu\'il puisse accéder à vos fichiers. Désactivez pour garder vos photos et téléchargements hors de portée de l\'environnement Linux local.</string>
    <string name="app_desktop_bind_android_system_title">Exposer le système Android au guest</string>
    <string name="app_desktop_bind_android_system_description">Monte dans le guest les partitions Android en lecture seule /system, /vendor, /apex et associées, pour qu\'il puisse exécuter les binaires natifs d\'Android (ex. getprop, toybox). Désactivé par défaut : cela expose les éléments internes de l\'appareil et du fabricant à l\'environnement Linux local.</string>
    <string name="app_desktop_custom_binds_title">Montages personnalisés (%1$d)</string>
    <string name="app_desktop_custom_binds_description">Expose des chemins Android supplémentaires dans le guest de cette distribution, en plus des montages système. Les montages sont en lecture-écriture.</string>
    <string name="app_desktop_custom_binds_dialog_title">Montages personnalisés — %1$s</string>
    <string name="app_desktop_custom_binds_host_hint">Chemin Android (ex. /storage/emulated/0/Sync)</string>
    <string name="app_desktop_custom_binds_guest_hint">Chemin dans le guest (facultatif — même chemin par défaut)</string>
    <string name="app_desktop_custom_binds_add">Ajouter un montage</string>
    <string name="app_desktop_custom_binds_empty">Aucun montage personnalisé. Ajoutez-en un pour exposer un chemin Android dans le guest.</string>
    <string name="app_desktop_custom_binds_remove_cd">Supprimer le montage</string>
    <string name="app_desktop_custom_binds_takes_effect">S\'applique au prochain démarrage d\'un shell, d\'une commande ou d\'un bureau pour cette distribution.</string>
    <string name="app_desktop_import_rootfs">Importer un rootfs…</string>
