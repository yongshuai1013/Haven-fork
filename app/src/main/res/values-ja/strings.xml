    <string name="app_desktop_compositor_title">コンポジタ</string>
    <string name="app_desktop_mirror_title">パッケージミラー</string>
    <string name="app_desktop_mirror_description">ディストリビューションのパッケージのダウンロード元です。近い地域を選ぶとインストールがより速く安定します。デフォルトでは各ディストリビューション自身の CDN を使用します。</string>
    <string name="app_desktop_mirror_default">デフォルト (CDN)</string>
    <string name="app_desktop_mirror_europe">ヨーロッパ</string>
    <string name="app_desktop_mirror_asia">アジア</string>
    <string name="app_desktop_mirror_americas">南北アメリカ</string>
    <string name="app_desktop_remap_ports_title">低番号ポートの再マッピング</string>
    <string name="app_desktop_remap_ports_description">ゲストのサービスが特権ポート（&lt;1024）でリッスンできるようにします。ポート N のサービスは N+2000 でアクセスできます（例: 80 → 2080）。Android はアプリが低番号ポートを直接バインドすることを許可しません。デフォルトはオフ。ゲストの sshd を含むすべての特権ポートに影響します。</string>
    <string name="app_desktop_share_storage_title">デバイスのストレージをゲストと共有</string>
    <string name="app_desktop_share_storage_description">共有ストレージをゲストの /storage と /sdcard にマウントし、ファイルへアクセスできるようにします。オフにすると、写真やダウンロードはローカル Linux 環境から見えなくなります。</string>
    <string name="app_desktop_bind_android_system_title">Android システムをゲストに公開</string>
    <string name="app_desktop_bind_android_system_description">Android の読み取り専用の /system、/vendor、/apex などのパーティションをゲストにマウントし、Android 自身のネイティブバイナリ（getprop、toybox など）を実行できるようにします。デフォルトはオフ: デバイスやベンダーの内部がローカル Linux 環境に公開されます。</string>
    <string name="app_desktop_custom_binds_title">カスタムマウント (%1$d)</string>
    <string name="app_desktop_custom_binds_description">システムマウントに加えて、追加の Android パスをこのディストリビューションのゲスト内に公開します。マウントは読み書き可能です。</string>
    <string name="app_desktop_custom_binds_dialog_title">カスタムマウント — %1$s</string>
    <string name="app_desktop_custom_binds_host_hint">Android パス（例: /storage/emulated/0/Sync）</string>
    <string name="app_desktop_custom_binds_guest_hint">ゲストパス（省略可 — デフォルトは同じパス）</string>
    <string name="app_desktop_custom_binds_add">マウントを追加</string>
    <string name="app_desktop_custom_binds_empty">カスタムマウントはまだありません。追加すると Android パスをゲスト内に公開できます。</string>
    <string name="app_desktop_custom_binds_remove_cd">マウントを削除</string>
    <string name="app_desktop_custom_binds_takes_effect">このディストリビューションで次にシェル、コマンド、またはデスクトップを起動したときに適用されます。</string>
    <string name="app_desktop_import_rootfs">rootfs をインポート…</string>
    <string name="app_desktop_options_section">オプションとマウント</string>
