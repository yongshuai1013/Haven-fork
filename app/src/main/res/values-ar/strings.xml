    <string name="app_desktop_compositor_title">المُركِّب (compositor)</string>
    <string name="app_desktop_mirror_title">مرآة الحزم</string>
    <string name="app_desktop_mirror_description">المصدر الذي تُنزَّل منه حزم التوزيعة. اختر منطقة أقرب إليك لتثبيت أسرع وأكثر موثوقية. الخيار الافتراضي يستخدم CDN الخاص بكل توزيعة.</string>
    <string name="app_desktop_mirror_default">افتراضي (CDN)</string>
    <string name="app_desktop_mirror_europe">أوروبا</string>
    <string name="app_desktop_mirror_asia">آسيا</string>
    <string name="app_desktop_mirror_americas">الأمريكتان</string>
    <string name="app_desktop_remap_ports_title">إعادة تعيين المنافذ المنخفضة</string>
    <string name="app_desktop_remap_ports_description">يتيح لخدمات الضيف الاستماع على المنافذ المميزة (&lt;1024): تصبح الخدمة على المنفذ N متاحة على N+2000 (مثلًا 80 ← 2080). يمنع Android التطبيق من ربط المنافذ المنخفضة مباشرة. معطّل افتراضيًا؛ يؤثر على كل منفذ مميز، بما في ذلك sshd الضيف.</string>
    <string name="app_desktop_share_storage_title">إتاحة تخزين الجهاز للضيف</string>
    <string name="app_desktop_share_storage_description">يركّب وحدة التخزين المشتركة داخل الضيف في /storage و /sdcard ليتمكن من الوصول إلى ملفاتك. أوقفه لإبقاء صورك وتنزيلاتك مخفية عن بيئة Linux المحلية.</string>
    <string name="app_desktop_bind_android_system_title">إتاحة نظام Android للضيف</string>
    <string name="app_desktop_bind_android_system_description">يركّب أقسام Android للقراءة فقط /system و /vendor و /apex وما يتصل بها داخل الضيف ليتمكن من تشغيل ثنائيات Android الأصلية (مثل getprop و toybox). معطّل افتراضيًا: هذا يكشف دواخل الجهاز والمصنّع لبيئة Linux المحلية.</string>
    <string name="app_desktop_custom_binds_title">نقاط تركيب مخصصة (%1$d)</string>
