    <string name="app_desktop_compositor_title">Compositor</string>
    <string name="app_desktop_mirror_title">Espelho de pacotes</string>
    <string name="app_desktop_mirror_description">De onde os pacotes da distro são baixados. Escolha uma região mais próxima de você para instalações mais rápidas e confiáveis. O padrão usa o CDN da própria distro.</string>
    <string name="app_desktop_mirror_default">Padrão (CDN)</string>
    <string name="app_desktop_mirror_europe">Europa</string>
    <string name="app_desktop_mirror_asia">Ásia</string>
    <string name="app_desktop_mirror_americas">Américas</string>
    <string name="app_desktop_remap_ports_title">Remapear portas baixas</string>
    <string name="app_desktop_remap_ports_description">Permite que serviços do convidado escutem em portas privilegiadas (&lt;1024): um serviço na porta N fica acessível em N+2000 (ex.: 80 → 2080). O Android impede o app de vincular portas baixas diretamente. Desativado por padrão; afeta todas as portas privilegiadas, incluindo um sshd do convidado.</string>
    <string name="app_desktop_share_storage_title">Compartilhar armazenamento do dispositivo com o convidado</string>
    <string name="app_desktop_share_storage_description">Monta seu armazenamento compartilhado no convidado em /storage e /sdcard para que ele acesse seus arquivos. Desative para manter suas fotos e downloads ocultos do ambiente Linux local.</string>
    <string name="app_desktop_bind_android_system_title">Expor o sistema Android ao convidado</string>
    <string name="app_desktop_bind_android_system_description">Monta as partições somente leitura /system, /vendor, /apex e relacionadas do Android no convidado, para que ele execute os binários nativos do próprio Android (ex.: getprop, toybox). Desativado por padrão: isso expõe detalhes internos do dispositivo e do fabricante ao ambiente Linux local.</string>
    <string name="app_desktop_custom_binds_title">Montagens personalizadas (%1$d)</string>
    <string name="app_desktop_custom_binds_description">Expõe caminhos extras do Android dentro do convidado desta distro, além das montagens do sistema. As montagens são de leitura e gravação.</string>
    <string name="app_desktop_custom_binds_dialog_title">Montagens personalizadas — %1$s</string>
    <string name="app_desktop_custom_binds_host_hint">Caminho do Android (ex.: /storage/emulated/0/Sync)</string>
    <string name="app_desktop_custom_binds_guest_hint">Caminho no convidado (opcional — usa o mesmo caminho por padrão)</string>
    <string name="app_desktop_custom_binds_add">Adicionar montagem</string>
    <string name="app_desktop_custom_binds_empty">Nenhuma montagem personalizada. Adicione uma para expor um caminho do Android no convidado.</string>
    <string name="app_desktop_custom_binds_remove_cd">Remover montagem</string>
    <string name="app_desktop_custom_binds_takes_effect">Aplica-se no próximo shell, comando ou início da área de trabalho desta distro.</string>
    <string name="app_desktop_import_rootfs">Importar rootfs…</string>
    <string name="app_desktop_options_section">Opções e montagens</string>
